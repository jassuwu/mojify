{
  "name": "mojify-monorepo",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "turbo run build && mkdir -p bin && cp packages/core/bin/mojify bin/mojify",
    "build:core": "turbo run build --filter=@mojify/core",
    "build:site": "turbo run build --filter=@mojify/site",
    "dev:all": "turbo run dev",
    "dev:core": "turbo run dev --filter=@mojify/core",
    "dev:site": "turbo run dev --filter=@mojify/site",
    "preview:site": "turbo run preview --filter=@mojify/site",
    "test": "turbo run test",
    "test:site": "turbo run test --filter=@mojify/site",
    "typecheck": "turbo run typecheck",
    "typecheck:site": "turbo run typecheck --filter=@mojify/site",
    "readme:header": "bash scripts/render-readme-header.sh",
    "qa:clips": "bash scripts/generate-qa-clips.sh",
    "qa:export": "bash scripts/export-qa.sh",
    "fmt": "gofmt -w packages/core",
    "fmt:check": "test -z \"$(gofmt -l packages/core)\""
  },
  "devDependencies": {
    "turbo": "^2.9.16"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*",
    "scripts"
  ]
}
